<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_gravity="center"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <!--<android.support.v7.widget.Toolbar
        android:id="@+id/my_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#005BB0"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"/>
        -->
    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="right"
        tools:context="com.ktds.jgbaek.myapp.RegistActivity"
        >

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/etNAME"
                android:gravity="right"
                android:hint="ຊື່ :"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etname"
                android:gravity="left"
                android:layout_width="40mm"
                android:layout_height="wrap_content"
                android:hint=""
                android:inputType="textCapWords" />

        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/etSURNAME"
                android:gravity="right"
                android:hint="ນາມສະກຸນ :"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etsurname"
                android:gravity="left"
                android:layout_width="40mm"
                android:layout_height="wrap_content"
                android:hint=""
                android:inputType="textCapWords" />

        </TableRow>


        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/etETHNIC"
                android:gravity="right"
                android:hint="ຊົນເຜົ່າ :"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etethnic"
                android:gravity="left"
                android:layout_width="40mm"
                android:layout_height="wrap_content"
                android:hint=""
                android:inputType="textCapWords" />

        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/etDATEOFBIRTH"
                android:gravity="right"
                android:hint="ວັນ​ເດືອນ​ປີ​ເກີດ :"
                android:textStyle="bold" />


            <EditText
                android:id="@+id/etdateofbirth"
                android:gravity="left"
                android:layout_width="40mm"
                android:layout_height="wrap_content"
                android:hint=" (YYYY-MM-DD) "
                android:maxLength="10"
                android:inputType="date" />


        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/etPHONENUMBER"
                android:gravity="right"
                android:hint="ເບີ​ໂທລະ​ສັບ :"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etphonenumber"
                android:gravity="left"
                android:layout_width="40mm"
                android:layout_height="wrap_content"
                android:ems="10"
                android:hint=""
                android:maxLength="12"
                android:inputType="phone" />
        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/etEMAIL"
                android:gravity="right"
                android:hint="ອີເມວ :"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etemail"
                android:gravity="left"
                android:layout_width="40mm"
                android:layout_height="wrap_content"
                android:ems="10"
                android:hint=""
                android:inputType="textEmailAddress" />
        </TableRow>

        <TableRow
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/etSNS"
                android:gravity="right"
                android:hint="ສື່ສັງຄົມອອນລາຍ :"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etsns"
                android:gravity="left"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="(ex:Facebook, Instagram)"
                android:inputType="textCapWords" />

        </TableRow>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnDone"
                style="?android:attr/buttonStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ຢືນຢັນ" />

            <Button
                android:id="@+id/btnCancel"
                style="?android:attr/buttonStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ຍົກເລີກ" />
        </LinearLayout>

    </TableLayout>

</LinearLayout>
